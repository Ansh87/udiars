# UDIARS Environment Configuration
# Copy to .env and fill in your values

# NASA FIRMS API (free registration at https://firms.modaps.eosdis.nasa.gov/api/)
NASA_FIRMS_API_KEY=your_firms_map_key_here

# Optional: Override default API base URLs
USGS_NWIS_URL=https://waterservices.usgs.gov/nwis/iv/
NOAA_MRMS_URL=https://mrms.ncep.noaa.gov/
USGS_EQ_URL=https://earthquake.usgs.gov/fdsnws/event/1/query
OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast
OPEN_ELEVATION_URL=https://api.open-elevation.com/api/v1/lookup

# Application settings
APP_HOST=0.0.0.0
APP_PORT=8000
REFRESH_INTERVAL_SECONDS=60

# OSMnx cache directory (stores downloaded road network)
OSMNX_CACHE_DIR=./cache/osmnx

# Demo mode (set to true to start in demo mode)
DEMO_MODE=false

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
